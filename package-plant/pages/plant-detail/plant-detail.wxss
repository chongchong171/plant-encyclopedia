/* 植物详情页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F5F5 30%);
  padding-bottom: 60rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
}

/* 植物头部 */
.plant-header {
  position: relative;
  width: 100%;
  height: 500rpx;
  margin: 0;
  padding: 0;
}

.plant-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.plant-name-box {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.plant-name {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
}

.plant-scientific {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  font-style: italic;
}

/* 养护概览 */
.care-overview {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: -30rpx 24rpx 24rpx;
  position: relative;
  z-index: 1;
}

.overview-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

.overview-item.today {
  border: 2rpx solid #ff7875;
  background: linear-gradient(135deg, #fff 0%, #FFF1F0 100%);
}

.overview-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.overview-info {
  flex: 1;
  min-width: 0;
}

.overview-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 6rpx;
}

.overview-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.overview-btn {
  font-size: 26rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  border: none;
  flex-shrink: 0;
}

.overview-btn:active {
  background: rgba(76, 175, 80, 0.2);
}

/* 基本信息卡片 */
.info-card {
  background-color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.info-list {
  margin-top: 16rpx;
}

/* 养护指南卡片 */
.care-guide-card {
  background-color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.guide-list {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.guide-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin: 0 6rpx;
}

.guide-item:first-child {
  margin-left: 0;
}

.guide-item:last-child {
  margin-right: 0;
}

.guide-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.guide-content {
  margin-top: 8rpx;
}

.guide-label {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.guide-value {
  font-size: 24rpx;
  color: #333;
  margin-top: 4rpx;
  display: block;
  line-height: 1.4;
}

/* 养护难度 */
.difficulty-box {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.difficulty-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 12rpx;
}

.difficulty-stars {
  margin-right: 12rpx;
}

.star {
  font-size: 28rpx;
  color: #ddd;
}

.star--active {
  color: #faad14;
}

.difficulty-text {
  font-size: 24rpx;
  color: #999;
}

/* 养护卡片 */
.care-card {
  background-color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.care-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.care-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.care-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2E7D32;
}

.care-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

.light-card {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.light-card .care-title {
  color: #F57C00;
}

/* 浇水状态 */
.watering-status-box {
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.watering-status-box.today {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.watering-status-box.soon {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.watering-status-box.ok {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
}

.watering-status-box.today .status-text {
  color: #D32F2F;
}

.watering-status-box.soon .status-text {
  color: #F57C00;
}

.watering-status-box.ok .status-text {
  color: #388E3C;
}

/* 信息行 */
.care-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #888;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 养护建议 */
.care-tips {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.tips-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
  display: block;
}

.tips-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

/* 操作按钮 */
.action-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.water-btn {
  background: linear-gradient(135deg, #409eff, #66b1ff);
  color: #fff;
  border: none;
}

.fertilize-btn {
  background: linear-gradient(135deg, #67c23a, #95d475);
  color: #fff;
  border: none;
}

/* 日志列表 */
.log-list {
  margin-top: 10rpx;
}

.log-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.log-item:last-child {
  border-bottom: none;
}

.log-date {
  font-size: 26rpx;
  color: #999;
  width: 160rpx;
}

.log-action {
  font-size: 28rpx;
  color: #333;
}

.log-notes {
  font-size: 26rpx;
  color: #666;
  margin-left: 16rpx;
}

.empty-log {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* AI 生成标识 - 低调合规 */
.ai-generate-tag {
  text-align: center;
  padding: 12rpx 0;
  margin-top: 24rpx;
  border-top: 1rpx solid #E8E8E8;
}

.ai-tag-text {
  font-size: 22rpx;
  color: #999;
  letter-spacing: 0.5rpx;
}