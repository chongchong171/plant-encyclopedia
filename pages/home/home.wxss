/* 养花助手 - 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4CAF50 0%, #66BB6A 40%, #81C784 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 36rpx;
  position: relative;
  overflow: hidden;
}

/* 绿叶浮雕背景 */
.leaf-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  align-content: flex-start;
  padding: 40rpx;
  opacity: 0.15;
  pointer-events: none;
}

.leaf {
  font-size: 120rpx;
  transform: rotate(-15deg);
}

.leaf-1 { transform: rotate(-20deg); margin-top: 20rpx; }
.leaf-2 { transform: rotate(15deg); margin-top: 80rpx; }
.leaf-3 { transform: rotate(-10deg); margin-top: 40rpx; }
.leaf-4 { transform: rotate(25deg); margin-top: 100rpx; }
.leaf-5 { transform: rotate(-5deg); margin-top: 60rpx; }

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  z-index: 1;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 主功能区 */
.func-section {
  width: 100%;
  z-index: 1;
}

/* 大按钮 - 拍照识别 */
.main-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.main-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.main-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.main-desc {
  font-size: 26rpx;
  color: #888;
}

/* 并列按钮 */
.sub-btns {
  display: flex;
  gap: 20rpx;
}

.sub-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.sub-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 底部 */
.footer {
  margin-top: auto;
  padding-top: 40rpx;
  z-index: 1;
}

.footer text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}