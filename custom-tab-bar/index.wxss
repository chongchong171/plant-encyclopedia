.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50px;
  background: transparent;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  padding-top: 20px;  /* 增加顶部间距，让 TabBar 整体往下移 */
}

/* 非首页样式：白色背景 */
.tab-bar:not(.tab-bar--home) {
  background: #FFFFFF;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid #F0F0F0;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 5px;
}

.tab-icon {
  width: 24px;
  height: 24px;
}

/* 非首页未选中图标变灰 */
.tab-bar:not(.tab-bar--home) .tab-icon {
  opacity: 0.35;
}

/* 选中图标不透明 */
.tab-bar-item--active .tab-icon {
  opacity: 1;
}

.tab-text {
  font-size: 10px;
  color: #999999;
  margin-top: 2px;
}

/* 非首页文字颜色 */
.tab-bar:not(.tab-bar--home) .tab-text {
  color: #999999;
}

.tab-text.active {
  color: #81C784;
  font-weight: 500;
}

/* 非首页选中文字颜色 */
.tab-bar:not(.tab-bar--home) .tab-text.active {
  color: #4CAF50;
}