<!-- 植物百科大全 - 识别结果页面 -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <image class="loading-image" src="{{imagePath}}" mode="aspectFill"></image>
    <view class="loading-overlay">
      <view class="loading-box">
        <view class="loading-spinner"></view>
        <text class="loading-text">🌱 AI 正在识别...</text>
      </view>
    </view>
  </view>

  <!-- 识别失败 -->
  <view class="error-container" wx:if="{{identifyError && !loading}}">
    <image class="error-image" src="{{imagePath}}" mode="aspectFill"></image>
    <view class="error-content">
      <text class="error-icon">😢</text>
      <text class="error-title">识别失败</text>
      <text class="error-message">{{errorMessage}}</text>
      <button class="retry-btn" bindtap="retryIdentify">📸 重新拍照</button>
    </view>
  </view>

  <!-- 识别成功 -->
  <view class="result-container" wx:if="{{!loading && !identifyError}}">
    <!-- 顶部图片 -->
    <view class="plant-header">
      <image class="plant-image" src="{{imagePath}}" mode="aspectFill"></image>
      <view class="image-gradient"></view>
      <view class="favorite-btn" bindtap="toggleFavorite">
        <text>{{isFavorite ? '❤️' : '🤍'}}</text>
      </view>
    </view>

    <!-- 植物卡片 -->
    <view class="plant-card">
      <!-- 名称 -->
      <view class="name-area">
        <text class="plant-name">{{plant.name}}</text>
        <text class="plant-scientific" wx:if="{{plant.scientificName}}">{{plant.scientificName}}</text>
        <view class="tag-row">
          <view class="tag tag-green">{{plant.difficulty}}</view>
          <view class="tag {{plant.toxicity ? 'tag-red' : 'tag-green'}}">
            {{plant.toxicity ? '⚠️ 有毒' : '✅ 无毒'}}
          </view>
        </view>
      </view>

      <!-- AI 识别结果 -->
      <view class="section">
        <view class="section-header">
          <text class="section-icon">🤖</text>
          <text class="section-title">AI 识别结果</text>
        </view>
        <view class="description-box">
          <text class="description-text">{{plant.description}}</text>
        </view>
      </view>

      <!-- 养护指南 -->
      <view class="section" wx:if="{{plant.careGuide}}">
        <view class="section-header">
          <text class="section-icon">🌿</text>
          <text class="section-title">养护指南</text>
        </view>
        
        <view class="care-grid">
          <view class="care-item">
            <text class="care-emoji">☀️</text>
            <text class="care-title">光照</text>
            <text class="care-text">{{plant.careGuide.light}}</text>
          </view>
          
          <view class="care-item">
            <text class="care-emoji">💧</text>
            <text class="care-title">浇水</text>
            <text class="care-text">{{plant.careGuide.water}}</text>
          </view>
          
          <view class="care-item">
            <text class="care-emoji">🌡️</text>
            <text class="care-title">温度</text>
            <text class="care-text">{{plant.careGuide.temperature}}</text>
          </view>

          <view class="care-item" wx:if="{{plant.careGuide.humidity}}">
            <text class="care-emoji">💦</text>
            <text class="care-title">湿度</text>
            <text class="care-text">{{plant.careGuide.humidity}}</text>
          </view>
        </view>

        <view class="care-tips" wx:if="{{plant.careGuide.tips}}">
          <text class="tips-icon">💡</text>
          <text class="tips-text">{{plant.careGuide.tips}}</text>
        </view>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-bar">
      <button class="btn-secondary" bindtap="retryIdentify">📷 再拍一张</button>
    </view>
  </view>
</view>