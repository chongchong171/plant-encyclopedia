/* 花草百科全书 - 拍照页面 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #C8E6C9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  position: relative;
}

/* 背景装饰 */
.leaf-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.leaf {
  position: absolute;
  font-size: 80rpx;
  opacity: 0.1;
  animation: float 6s ease-in-out infinite;
}

.leaf-1 { top: 10%; left: 10%; animation-delay: 0s; }
.leaf-2 { top: 30%; right: 15%; animation-delay: 1.5s; }
.leaf-3 { bottom: 30%; left: 20%; animation-delay: 3s; }
.leaf-4 { bottom: 10%; right: 10%; animation-delay: 4.5s; }

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-30rpx) rotate(10deg); }
}

/* 拍摄提示 */
.photo-tips {
  position: relative;
  margin-top: 80rpx;
  margin-bottom: 60rpx;
}

.tip-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.15);
}

.tip-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.tip-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
}

.tip-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.tip-dots {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.dot {
  font-size: 20rpx;
  color: #ccc;
  margin: 0 8rpx;
  transition: color 0.3s;
}

.dot.active {
  color: #4CAF50;
}

.tip-close {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 56rpx;
  height: 56rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 操作按钮区 */
.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.action-btn {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s, box-shadow 0.2s;
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.camera-btn {
  border: 3rpx solid #4CAF50;
}

.album-btn {
  border: 3rpx solid #81C784;
}

.action-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.action-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 26rpx;
  color: #999;
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  top: 40rpx;
  left: 40rpx;
  background: rgba(255, 255, 255, 0.9);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #4CAF50;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}