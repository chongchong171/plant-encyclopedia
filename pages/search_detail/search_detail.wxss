/* 植物百科大全 - 搜索详情页面样式 */

.container {
  min-height: 100vh;
  background: #E8F5E9;
  padding: 30rpx;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  padding: 0 20rpx;
}

.search-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 搜索建议 */
.suggest-section {
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.suggest-item {
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
  font-size: 30rpx;
  color: #333;
}

.suggest-item:last-child {
  border-bottom: none;
}

/* 区块标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #f44336;
}

/* 搜索历史 */
.history-section {
  margin-top: 40rpx;
}

.history-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.history-text {
  font-size: 30rpx;
  color: #333;
}

/* 热门搜索 */
.hot-section {
  margin-top: 40rpx;
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.hot-item {
  background: white;
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #4CAF50;
}