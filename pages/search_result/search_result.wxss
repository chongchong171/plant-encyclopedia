/* 植物百科大全 - 搜索结果页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F5F5 100%);
  padding-bottom: 140rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80vh;
}

.loading-text {
  font-size: 32rpx;
  color: #4CAF50;
}

/* 结果展示 */
.result-container {
  padding-bottom: 30rpx;
}

/* 植物图片 */
.plant-image-section {
  width: 100%;
  height: 600rpx;
  position: relative;
}

.plant-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
}

/* 图片占位 */
.plant-image-placeholder {
  width: 100%;
  height: 600rpx;
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.favorite-btn-top {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
}

.placeholder-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.placeholder-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: bold;
}

/* 信息区域 */
.info-section {
  background: white;
  margin: -40rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

/* 名称区域 */
.name-box {
  text-align: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #F0F0F0;
  margin-bottom: 24rpx;
}

.plant-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 10rpx;
}

.plant-common-names {
  display: block;
  font-size: 30rpx;
  color: #4CAF50;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.plant-scientific {
  display: block;
  font-size: 26rpx;
  color: #999;
  font-style: italic;
  margin-bottom: 6rpx;
}

.plant-family, .plant-origin {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

/* 区块卡片 */
.section-card {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.section-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 信息卡片 */
.info-card {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.info-card.highlight {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.info-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-card-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.info-card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.info-card-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 养护难度 */
.difficulty-section {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.difficulty-section .section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.difficulty-section .section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #2E7D32;
}

.difficulty-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 32rpx;
  color: #BDBDBD;
}

.star.active {
  color: #FFC107;
}

.difficulty-text {
  display: block;
  font-size: 26rpx;
  color: #4CAF50;
}

/* 养护指南 */
.care-section {
  margin-bottom: 20rpx;
}

.care-section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #4CAF50;
}

.care-card {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.care-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.care-card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.care-card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.care-card-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 快速要点 */
.quick-tips {
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #F57C00;
  margin-bottom: 12rpx;
}

.tips-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 10rpx 16rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.tip-dot {
  color: #F57C00;
  margin-right: 8rpx;
}

.tip-text {
  color: #555;
}

/* 养护禁忌 */
.taboos-section {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.taboos-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #C62828;
  margin-bottom: 10rpx;
}

.taboos-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
  text-align: center;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.retry-btn {
  background: #4CAF50;
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.action-btn {
  width: 100%;
  height: 90rpx;
  background: #4CAF50;
  color: white;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
}