/* 个人中心页面 */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* ========== 头图区域 ========== */
.header-section {
  position: relative;
  height: 568rpx;
  overflow: hidden;
  padding-top: 88rpx;
  box-sizing: border-box;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 180rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
  margin-bottom: 20rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.bio {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ========== 统计数据 ========== */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  margin: -40rpx 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: #E8E8E8;
}

/* ========== 区块 ========== */
.section {
  margin: 0 32rpx 24rpx;
  padding-top: 48rpx;
}

/* ========== 功能入口网格 ========== */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.action-icon-wrap.green {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.action-icon-wrap.red {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.action-icon-wrap.blue {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.action-icon-wrap.gold {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.action-icon {
  font-size: 40rpx;
}

.action-name {
  font-size: 24rpx;
  color: #555;
}

/* ========== 菜单列表 ========== */
.menu-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FAFAFA;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-badge {
  margin-right: 16rpx;
}

.badge-num {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  min-width: 30rpx;
  text-align: right;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
}

/* ========== 底部 ========== */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #BBB;
}