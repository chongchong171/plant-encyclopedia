/* 养花助手 - 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4CAF50 0%, #81C784 50%, #E8F5E9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  padding-bottom: 120rpx;
}

/* 顶部区域 */
.header {
  text-align: center;
  margin-top: 60rpx;
  margin-bottom: 60rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.2));
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
}

/* 主要操作区 */
.main-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.action-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.camera-card {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

.camera-card .action-emoji {
  font-size: 100rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.2));
}

.album-card {
  background: white;
  border: 4rpx solid #4CAF50;
}

.album-card .action-emoji {
  font-size: 100rpx;
}

.action-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.action-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.camera-card .action-title {
  color: white;
}

.action-desc {
  font-size: 28rpx;
  color: #999;
}

.camera-card .action-desc {
  color: rgba(255, 255, 255, 0.8);
}

/* 测试按钮 */
.test-section {
  margin: 30rpx 0;
}

.test-btn {
  background: #FF9800;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
}

/* 搜索植物入口 */
.search-section {
  width: 100%;
  margin-bottom: 120rpx;
}

.search-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.search-left {
  display: flex;
  align-items: center;
}

.search-emoji {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.search-info {
  display: flex;
  flex-direction: column;
}

.search-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.search-desc {
  font-size: 24rpx;
  color: #999;
}

.search-arrow {
  font-size: 48rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* 底部提示 */
.footer-tip {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding-bottom: env(safe-area-inset-bottom);
}