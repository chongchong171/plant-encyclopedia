/* 养花助手 - 首页样式 - 女性化设计 */

.container {
  min-height: 100vh;
  background: linear-gradient(165deg, #E8F5E9 0%, #F1F8E9 50%, #FFF8E1 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 36rpx;
}

/* 顶部装饰 */
.header-decor {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.decor-flower {
  font-size: 28rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.logo-circle {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #81C784 0%, #A5D6A7 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(129, 199, 132, 0.3);
}

.logo-icon {
  font-size: 60rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #2E7D32;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.slogan {
  font-size: 24rpx;
  color: #81C784;
}

/* 主要功能区 */
.main-section {
  width: 100%;
}

/* 功能卡片 */
.func-card {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.camera-card .card-icon-wrap {
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}

.album-card .card-icon-wrap {
  background: linear-gradient(135deg, #FFECB3 0%, #FFE082 100%);
}

.search-card .card-icon-wrap {
  background: linear-gradient(135deg, #B2DFDB 0%, #80CBC4 100%);
}

.card-icon {
  font-size: 36rpx;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
}

.card-arrow {
  font-size: 36rpx;
  color: #C8E6C9;
  font-weight: 300;
}

/* 底部装饰 */
.footer-decor {
  margin-top: auto;
  padding-top: 40rpx;
}

.footer-decor text {
  font-size: 22rpx;
  color: #A5D6A7;
  letter-spacing: 1rpx;
}