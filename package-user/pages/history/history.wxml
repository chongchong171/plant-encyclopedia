<!-- 历史记录页面 -->
<view class="container">
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{history.length === 0}}">
    <text class="empty-icon">📸</text>
    <text class="empty-title">暂无识别记录</text>
    <text class="empty-desc">拍照识别植物后会有记录</text>
    <button class="go-btn" bindtap="goToHome">去识别</button>
  </view>

  <!-- 历史列表 -->
  <view class="history-list" wx:if="{{history.length > 0}}">
    <view class="list-header">
      <text class="list-title">识别历史</text>
      <text class="clear-btn" bindtap="clearHistory">清空</text>
    </view>

    <view 
      class="history-item" 
      wx:for="{{history}}" 
      wx:key="id"
      data-plant="{{item}}"
      bindtap="goToDetail"
    >
      <image class="plant-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="plant-info">
        <text class="plant-name">{{item.name}}</text>
        <text class="plant-family">{{item.family}}</text>
        <text class="identify-time">{{item.timeStr}}</text>
      </view>
      <view class="arrow">
        <text>›</text>
      </view>
    </view>
  </view>
</view>