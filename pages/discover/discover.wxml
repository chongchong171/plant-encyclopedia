<!-- 发现页面 - 简洁实用风格 -->
<view class="container">
  <!-- 头图区域（拓展到顶部） -->
  <view class="header-section">
    <image class="header-bg" src="/image/discover-header.jpg" mode="aspectFill"></image>
    <view class="header-overlay"></view>
    <!-- 状态栏占位 -->
    <view class="status-bar" style="height: var(--status-bar-height)"></view>
    <!-- 自定义导航栏 -->
    <view class="custom-navbar">
      <view class="navbar-left" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="navbar-title">发现植物</text>
      <view class="navbar-right"></view>
    </view>
    <view class="header-content">
      <text class="header-title">发现植物</text>
      <text class="header-subtitle">探索植物知识，学习养护技巧</text>
    </view>
  </view>

  <!-- 搜索输入框（胶囊对话框 - 文字搜索） -->
  <view class="search-section">
    <view class="search-capsule">
      <view class="search-input-wrap">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="输入植物名称，AI 为你解答..."
          value="{{searchText}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
          confirm-type="search"
          cursor-spacing="200"
        />
        <text class="search-ai-icon" wx:if="{{searchText}}">🤖</text>
      </view>
    </view>
  </view>

  <!-- 热门搜索（带图片） -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🔥 热门搜索</text>
    </view>
    <view class="hot-plants-grid">
      <view class="hot-plant-card" wx:for="{{hotSearches}}" wx:key="name" bindtap="goToSearch" data-name="{{item.name}}">
        <!-- 有图片时显示图片 -->
        <image wx:if="{{item.imageUrl}}" class="hot-plant-img" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
        <!-- 无图片时显示占位符 -->
        <view wx:else class="hot-plant-placeholder">
          <text class="placeholder-emoji">🌿</text>
        </view>
        <text class="hot-plant-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 新手友好 - 按场景分类（竖向卡片） -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🌱 新手友好</text>
    </view>
    <view class="category-grid">
      <view class="category-card" wx:for="{{plantCategories}}" wx:key="id" bindtap="goToCategory" data-category="{{item}}">
        <!-- 图标 -->
        <view class="card-icon">{{item.icon}}</view>
        <view class="card-content">
          <text class="card-name">{{item.name}}</text>
          <text class="card-desc">{{item.desc}}</text>
        </view>
        <view class="card-features">
          <text class="feature-item" wx:for="{{item.features}}" wx:key="*this" wx:for-item="feature">{{feature}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 养护小贴士 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">💡 养护小贴士</text>
    </view>
    <view class="tips-list">
      <view class="tip-card" wx:for="{{careTips}}" wx:key="title">
        <view class="tip-header">
          <text class="tip-icon">{{item.icon}}</text>
          <text class="tip-title">{{item.title}}</text>
        </view>
        <text class="tip-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 底部固定白色区域 -->
  <view class="bottom-fixed"></view>
</view>
