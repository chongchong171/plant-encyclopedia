<!-- 植物百科大全 - 识别结果页面 -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <image class="loading-image" src="{{imagePath}}" mode="aspectFill"></image>
    <view class="loading-overlay">
      <view class="loading-box">
        <view class="loading-spinner"></view>
        <text class="loading-text">🌱 AI 正在识别...</text>
      </view>
    </view>
  </view>

  <!-- 识别失败 -->
  <view class="error-container" wx:if="{{identifyError && !loading}}">
    <image class="error-image" src="{{imagePath}}" mode="aspectFill"></image>
    <view class="error-content">
      <text class="error-icon">😢</text>
      <text class="error-title">识别失败</text>
      <text class="error-message">{{errorMessage}}</text>
      <button class="retry-btn" bindtap="retryIdentify">📸 重新拍照</button>
    </view>
  </view>

  <!-- 识别成功 -->
  <view class="result-container" wx:if="{{!loading && !identifyError}}">
    <!-- 顶部图片 -->
    <view class="plant-header">
      <image class="plant-image" src="{{imagePath}}" mode="aspectFill"></image>
      <view class="favorite-btn" bindtap="toggleFavorite">
        <text>{{isFavorite ? '❤️' : '🤍'}}</text>
      </view>
      <!-- 来源标签 -->
      <view class="source-tag">{{plant.source}}</view>
    </view>

    <!-- 植物卡片 -->
    <view class="plant-card">
      <!-- 名称 -->
      <view class="name-area">
        <text class="plant-name">{{plant.name}}</text>
        <text class="plant-scientific" wx:if="{{plant.scientificName}}">{{plant.scientificName}}</text>
        
        <!-- 置信度（仅 PlantNet 显示） -->
        <view class="confidence-bar" wx:if="{{plant.confidence > 0}}">
          <text class="confidence-label">置信度</text>
          <view class="confidence-track">
            <view class="confidence-fill" style="width: {{plant.confidence}}%"></view>
          </view>
          <text class="confidence-value">{{plant.confidence}}%</text>
        </view>
        
        <view class="tag-row">
          <view class="tag tag-green">养护难度：中等</view>
        </view>
      </view>

      <!-- AI 识别结果 - 逐行显示 -->
      <view class="section" wx:if="{{plant.descriptionLines.length > 0}}">
        <view class="section-header">
          <text class="section-icon">🤖</text>
          <text class="section-title">识别详情</text>
        </view>
        <view class="result-lines">
          <view class="result-line {{item.type}}" wx:for="{{plant.descriptionLines}}" wx:key="index">
            <text class="line-dot">{{item.type === 'care' ? '🌿' : '•'}}</text>
            <text class="line-text">{{item.text}}</text>
          </view>
        </view>
      </view>

      <!-- 养护指南卡片 -->
      <view class="care-card">
        <view class="care-title">
          <text class="care-icon">🌿</text>
          <text>养护指南</text>
        </view>
        <view class="care-items">
          <view class="care-row">
            <text class="care-emoji">☀️</text>
            <text class="care-label">光照</text>
            <text class="care-value">{{plant.careGuide.light}}</text>
          </view>
          <view class="care-row">
            <text class="care-emoji">💧</text>
            <text class="care-label">浇水</text>
            <text class="care-value">{{plant.careGuide.water}}</text>
          </view>
          <view class="care-row">
            <text class="care-emoji">🌡️</text>
            <text class="care-label">温度</text>
            <text class="care-value">{{plant.careGuide.temperature}}</text>
          </view>
        </view>
      </view>
      
      <!-- 额度提示 -->
      <view class="quota-tip" wx:if="{{plant.quotaRemaining !== undefined}}">
        <text>📊 今日剩余额度：{{plant.quotaRemaining}} 次</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="bottom-bar">
      <button class="btn-secondary" bindtap="retryIdentify">📷 再拍一张</button>
    </view>
  </view>
</view>