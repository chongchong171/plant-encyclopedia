/* 养花助手 - 分类列表页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 30rpx;
}

/* 加载中 */
.loading-section {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 分类头部 */
.category-header {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.15);
  border: 2rpx solid rgba(76, 175, 80, 0.1);
}

.category-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
  padding: 20rpx;
  border-radius: 16rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 12rpx;
}

.category-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 植物列表 */
.plant-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.12);
  border: 2rpx solid rgba(76, 175, 80, 0.08);
}

.plant-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
  transition: all 0.3s;
}

.plant-item:active {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
}

.plant-item:last-child {
  border-bottom: none;
}

.plant-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.15);
}

/* 无图片占位符 */
.plant-img-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 2rpx dashed #A5D6A7;
  box-sizing: border-box;
}

.placeholder-icon {
  font-size: 48rpx;
}

.plant-info {
  flex: 1;
  min-width: 0;
}

.plant-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #1B5E20;
  margin-bottom: 12rpx;
}

.plant-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  background: linear-gradient(135deg, #F1F8E9 0%, #E8F5E9 100%);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid #4CAF50;
}

.plant-arrow {
  font-size: 40rpx;
  color: #4CAF50;
  margin-left: 20rpx;
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}