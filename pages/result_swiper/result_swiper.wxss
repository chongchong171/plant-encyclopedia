/* 植物百科大全 - 识别结果页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F5F5 100%);
}

/* === 加载中 === */
.loading-container {
  position: relative;
  width: 100%;
  height: 100vh;
}

.loading-image {
  width: 100%;
  height: 100%;
  filter: blur(20rpx);
  transform: scale(1.1);
}

.loading-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-box {
  background: white;
  padding: 60rpx 80rpx;
  border-radius: 30rpx;
  text-align: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #E8F5E9;
  border-top-color: #4CAF50;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-size: 30rpx;
  color: #4CAF50;
}

/* === 识别失败 === */
.error-container { padding: 40rpx; }

.error-image {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
}

.error-content {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.error-icon { font-size: 80rpx; }

.error-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0;
}

.error-message {
  display: block;
  font-size: 28rpx;
  color: #666;
  background: #FFF3E0;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.retry-btn {
  background: #4CAF50;
  color: white;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 24rpx 60rpx;
}

/* === 结果展示 === */
.result-container { padding-bottom: 160rpx; }

/* 顶部图片 */
.plant-header {
  position: relative;
  width: 100%;
  height: 480rpx;
}

.plant-image { width: 100%; height: 100%; }

.favorite-btn {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 植物卡片 */
.plant-card {
  background: white;
  margin: -60rpx 24rpx 0;
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* 名称区域 */
.name-area {
  text-align: center;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #F0F0F0;
  margin-bottom: 30rpx;
}

.plant-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1B5E20;
  margin-bottom: 20rpx;
}

.tag-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.tag {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.tag-green { background: #E8F5E9; color: #4CAF50; }
.tag-red { background: #FFEBEE; color: #E53935; }

/* 信息区块 */
.section { margin-bottom: 30rpx; }

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 结果行 - 拆分显示 */
.result-lines {
  background: #FAFAFA;
  border-radius: 20rpx;
  padding: 20rpx;
}

.result-line {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.result-line:last-child {
  border-bottom: none;
}

.result-line.care {
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  margin: 8rpx 0;
}

.line-dot {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.line-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  flex: 1;
}

/* 养护卡片 */
.care-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.care-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.care-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.care-title text:last-child {
  font-size: 30rpx;
  font-weight: bold;
  color: #2E7D32;
}

.care-items {
  background: white;
  border-radius: 16rpx;
  padding: 16rpx;
}

.care-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.care-row:last-child {
  border-bottom: none;
}

.care-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

.care-label {
  font-size: 26rpx;
  color: #666;
  width: 80rpx;
}

.care-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.btn-secondary {
  width: 100%;
  height: 90rpx;
  background: white;
  color: #4CAF50;
  border: 4rpx solid #4CAF50;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
}