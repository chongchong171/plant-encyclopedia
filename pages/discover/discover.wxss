/* 养花助手 - 发现页面样式 */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 30rpx;
}

/* 区块 */
.section {
  background: white;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

/* 当季推荐横向滚动 */
.plant-scroll {
  white-space: nowrap;
}

.plant-card {
  display: inline-block;
  width: 220rpx;
  margin-right: 20rpx;
  vertical-align: top;
}

.plant-card:last-child {
  margin-right: 0;
}

.plant-img {
  width: 220rpx;
  height: 180rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.plant-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.plant-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  white-space: normal;
}

/* 养护小贴士 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-card {
  display: flex;
  align-items: flex-start;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.tip-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 热门搜索 */
.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #2E7D32;
}

/* 新手推荐 */
.beginner-list {
  display: flex;
  flex-direction: column;
}

.beginner-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F0F0F0;
}

.beginner-item:last-child {
  border-bottom: none;
}

.beginner-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.beginner-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.beginner-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.beginner-diff {
  font-size: 24rpx;
  color: #4CAF50;
}

.beginner-arrow {
  font-size: 36rpx;
  color: #CCC;
}