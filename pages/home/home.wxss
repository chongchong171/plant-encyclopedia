/* 花草百科全书 - 首页样式 */

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  background: #E8F5E9;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* ========== 背景装饰 ========== */
.leaf-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.leaf {
  position: absolute;
  opacity: 0.12;
}

.leaf-1 {
  font-size: 480rpx;
  top: -120rpx;
  left: -100rpx;
  transform: rotate(-25deg);
}

.leaf-2 {
  font-size: 420rpx;
  top: 80rpx;
  right: -130rpx;
  transform: rotate(35deg);
}

.leaf-3 {
  font-size: 380rpx;
  bottom: 180rpx;
  left: -80rpx;
  transform: rotate(-40deg);
}

.leaf-4 {
  font-size: 450rpx;
  bottom: -150rpx;
  right: -60rpx;
  transform: rotate(20deg);
}

/* ========== Logo 区域 ========== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  z-index: 1;
}

.logo-icon {
  font-size: 90rpx;
  margin-bottom: 16rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 10rpx;
}

.slogan {
  font-size: 24rpx;
  color: #81C784;
}

/* ========== 主功能区 ========== */
.func-section {
  width: 100%;
  z-index: 1;
}

/* ========== 大按钮 ========== */
.main-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4CAF50;
  border-radius: 45rpx;
  padding: 36rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.28);
}

.main-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.main-text {
  display: flex;
  flex-direction: column;
  text-align: center;
}

.main-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 6rpx;
}

.main-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ========== 并列按钮 ========== */
.sub-btns {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.sub-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  padding: 32rpx 24rpx;
}

.album-btn {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFE082 100%);
  box-shadow: 
    0 6rpx 18rpx rgba(255, 193, 7, 0.18),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5);
}

.search-btn {
  background: linear-gradient(135deg, #E0F7FA 0%, #80DEEA 100%);
  box-shadow: 
    0 6rpx 18rpx rgba(0, 188, 212, 0.18),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5);
}

.sub-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* ========== 底部 Slogan ========== */
.footer-slogan {
  text-align: center;
  padding: 30rpx 0;
}

.footer-slogan text {
  font-size: 24rpx;
  color: #81C784;
  letter-spacing: 1rpx;
}

/* 重置 button 默认样式 */
.sub-btn::after {
  border: none;
}

.sub-btn {
  margin: 0;
  padding: 32rpx 24rpx;
  line-height: normal;
}