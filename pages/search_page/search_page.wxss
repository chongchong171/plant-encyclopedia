/* 植物百科大全 - 搜索页面样式 */

.container {
  min-height: 100vh;
  background: #E8F5E9;
  padding: 30rpx;
}

/* 搜索区域 */
.search-section {
  margin-bottom: 40rpx;
}

.search-box {
  background: white;
  border-radius: 40rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.search-placeholder {
  font-size: 30rpx;
  color: #999;
}

/* 区块标题 */
.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 热门标签 */
.hot-section {
  margin-bottom: 40rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.hot-tag {
  background: white;
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #4CAF50;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 分类列表 */
.category-section {
  margin-bottom: 40rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  width: calc(50% - 10rpx);
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.category-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.category-name {
  font-size: 30rpx;
  color: #333;
}