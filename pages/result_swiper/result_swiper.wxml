<!-- 植物百科大全 - 识别结果页面 -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <image class="loading-image" src="{{imagePath}}" mode="aspectFill"></image>
    <view class="loading-overlay">
      <view class="loading-text">
        <text>🌱 正在识别植物...</text>
      </view>
    </view>
  </view>

  <!-- 识别失败 -->
  <view class="error-container" wx:if="{{identifyError && !loading}}">
    <image class="error-image" src="{{imagePath}}" mode="aspectFill"></image>
    <view class="error-content">
      <text class="error-title">识别失败</text>
      <text class="error-message">{{errorMessage}}</text>
      <button class="retry-btn" bindtap="retryIdentify">重新拍照</button>
    </view>
  </view>

  <!-- 识别成功 -->
  <view class="result-container" wx:if="{{!loading && !identifyError}}">
    <!-- 植物图片 -->
    <view class="plant-image-container">
      <image class="plant-image" src="{{imagePath}}" mode="aspectFill"></image>
      <view class="favorite-btn" bindtap="toggleFavorite">
        <text class="favorite-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
      </view>
    </view>

    <!-- 植物信息 -->
    <view class="plant-info">
      <!-- 名称区域 -->
      <view class="name-section">
        <text class="plant-name">{{plant.name}}</text>
        <text class="plant-scientific">{{plant.scientificName}}</text>
        <view class="tags">
          <text class="tag tag-difficulty">{{plant.difficulty}}</text>
          <text class="tag tag-toxicity" wx:if="{{plant.toxicity}}">⚠️ 有毒</text>
          <text class="tag tag-safe" wx:else>✅ 无毒</text>
        </view>
      </view>

      <!-- 基本信息 -->
      <view class="info-section">
        <text class="section-title">基本信息</text>
        <view class="info-item">
          <text class="info-label">科属：</text>
          <text class="info-value">{{plant.family}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">简介：</text>
          <text class="info-value">{{plant.description}}</text>
        </view>
      </view>

      <!-- 养殖指南 -->
      <view class="care-section" wx:if="{{plant.careGuide}}">
        <text class="section-title">🌿 养殖指南</text>
        
        <view class="care-item">
          <text class="care-icon">☀️</text>
          <view class="care-content">
            <text class="care-label">光照</text>
            <text class="care-value">{{plant.careGuide.light}}</text>
          </view>
        </view>

        <view class="care-item">
          <text class="care-icon">💧</text>
          <view class="care-content">
            <text class="care-label">浇水</text>
            <text class="care-value">{{plant.careGuide.water}}</text>
          </view>
        </view>

        <view class="care-item">
          <text class="care-icon">🌡️</text>
          <view class="care-content">
            <text class="care-label">温度</text>
            <text class="care-value">{{plant.careGuide.temperature}}</text>
          </view>
        </view>

        <view class="care-item" wx:if="{{plant.careGuide.humidity}}">
          <text class="care-icon">💦</text>
          <view class="care-content">
            <text class="care-label">湿度</text>
            <text class="care-value">{{plant.careGuide.humidity}}</text>
          </view>
        </view>

        <view class="care-item" wx:if="{{plant.careGuide.fertilizer}}">
          <text class="care-icon">🌱</text>
          <view class="care-content">
            <text class="care-label">施肥</text>
            <text class="care-value">{{plant.careGuide.fertilizer}}</text>
          </view>
        </view>

        <view class="care-item" wx:if="{{plant.careGuide.tips}}">
          <text class="care-icon">💡</text>
          <view class="care-content">
            <text class="care-label">养护技巧</text>
            <text class="care-value">{{plant.careGuide.tips}}</text>
          </view>
        </view>
      </view>

      <!-- 特点 -->
      <view class="features-section" wx:if="{{plant.features && plant.features.length > 0}}">
        <text class="section-title">✨ 特点</text>
        <view class="features-list">
          <text class="feature-tag" wx:for="{{plant.features}}" wx:key="index">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-actions">
      <button class="action-btn secondary" bindtap="retryIdentify">再拍一张</button>
    </view>
  </view>
</view>