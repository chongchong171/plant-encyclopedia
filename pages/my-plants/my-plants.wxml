<!-- 我的花园页面 - 简洁陈列式布局 -->
<view class="container">
  <!-- 头图区域（拓展到顶部） -->
  <view class="header-section">
    <image class="header-bg" src="/image/garden-header.jpg" mode="aspectFill"></image>
    <view class="header-overlay"></view>
    <!-- 状态栏占位 -->
    <view class="status-bar" style="height: var(--status-bar-height)"></view>
    <!-- 自定义导航栏 -->
    <view class="custom-navbar">
      <view class="navbar-left" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="navbar-title">我的花园</text>
      <view class="navbar-right"></view>
    </view>
    <view class="header-content">
      <text class="header-title">我的花园</text>
      <text class="header-subtitle">用心呵护每一株生命</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-section" wx:if="{{!loading}}">
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-num">{{actualPlantCount}}</text>
        <text class="stat-label">全部植物</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{todayPlants.length}}</text>
        <text class="stat-label">待浇水</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onAddPlantEntry">
        <text class="stat-num">➕</text>
        <text class="stat-label">添加</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && actualPlantCount === 0}}" class="empty-state">
    <text class="empty-icon">🌱</text>
    <text class="empty-title">你的花园还是空的</text>
    <text class="empty-tip">去首页识别植物，添加第一盆吧</text>
    <view class="empty-btn" bindtap="goToHome">开始识别</view>
  </view>

  <!-- 诊断悬浮按钮（右下角呼吸灯） -->
  <view class="diagnosis-float-btn" bindtap="onDiagnosisFloatTap">
    <text class="float-btn-icon">🩺</text>
    <text class="float-btn-text">诊断</text>
  </view>

  <!-- 植物陈列列表 -->
  <view wx:if="{{!loading && actualPlantCount > 0}}" class="plant-section">
    <view class="section-title">
      <text class="title-text">植物列表</text>
      <text class="title-count">共 {{actualPlantCount}} 株</text>
    </view>
    
    <view class="plant-list">
      <view wx:for="{{plants}}" wx:key="_id" class="plant-item" bindtap="onPlantTap" data-plant-id="{{item._id}}">
        <view class="plant-img-wrapper">
          <block wx:if="{{!item.hasImage}}">
            <!-- 没有照片，显示灰色加号 -->
            <view class="plant-img-placeholder" catchtap="onAddPhotoTap" data-plant-id="{{item._id}}" data-plant-name="{{item.displayName || item.name}}">
              <text class="placeholder-plus">+</text>
              <text class="placeholder-text">添加照片</text>
            </view>
          </block>
          <block wx:else>
            <image class="plant-img" 
                   src="{{item.userImageUrl || item.imageUrl}}" 
                   mode="aspectFill"
                   binderror="onImageError"
                   wx:if="{{item.userImageUrl || item.imageUrl}}"></image>
            <view class="plant-img-placeholder" wx:else>
              <text class="placeholder-plus">?</text>
              <text class="placeholder-text">暂无图片</text>
            </view>
          </block>
          <view wx:if="{{item.statusType === 'water'}}" class="status-icon water">💧</view>
          <view wx:elif="{{item.statusType === 'sun'}}" class="status-icon sun">☀️</view>
        </view>
        <view class="plant-info">
          <view class="plant-top">
            <view class="plant-name">{{item.displayName || '未命名'}}</view>
            <view class="plant-actions">
              <view class="action-btn edit-btn" catchtap="onEditTap" data-plant-id="{{item._id}}">✏️</view>
              <view class="action-btn delete-btn" catchtap="onDeleteTap" data-plant-id="{{item._id}}" data-plant-name="{{item.displayName}}">🗑️</view>
            </view>
          </view>
          
          <!-- 第二行：浇水周期 + 倒计时 -->
          <view class="plant-middle">
            <text wx:if="{{item.careInfo && item.careInfo.wateringDays}}" class="water-info">💧 {{item.careInfo.wateringDays}}天</text>
            <text wx:if="{{item.daysUntilWater >= 0}}" class="days-info">· {{item.daysUntilWater}}天后</text>
          </view>
          
          <!-- 第三行：光照 + 温度标签 -->
          <view class="plant-bottom">
            <text wx:if="{{item.lightTag}}" class="tag {{item.lightTagClass}}">{{item.lightTag}}</text>
            <text wx:if="{{item.tempTag}}" class="tag {{item.tempTagClass}}">{{item.tempTag}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 编辑植物弹窗 -->
  <view wx:if="{{showEditModal}}" class="edit-modal-overlay" bindtap="closeEditModal">
    <view class="edit-modal-content" catchtap="preventBubble">
      <scroll-view scroll-y class="edit-scroll">
        <text class="edit-modal-title">编辑植物</text>
        
        <!-- 植物图片编辑 -->
        <view class="form-item form-image-item">
          <text class="form-label">植物图片</text>
          <view class="image-editor">
            <view class="current-image" wx:if="{{editPlantImageUrl}}" bindtap="onChangeImage">
              <image class="plant-preview" src="{{editPlantImageUrl}}" mode="aspectFill"></image>
              <view class="change-hint">点击更换</view>
            </view>
            <view class="upload-placeholder" wx:else bindtap="onChangeImage">
              <text class="upload-plus">+</text>
              <text class="upload-text">添加图片</text>
            </view>
          </view>
        </view>
        
        <view class="edit-form">
          <view class="form-item">
            <text class="form-label">植物名称</text>
            <input class="form-input" placeholder="请输入植物名称" value="{{editPlantName}}" bindinput="onEditNameInput"/>
          </view>
          <view class="form-item">
            <text class="form-label">植物别名</text>
            <input class="form-input" placeholder="如有别名，用顿号分隔" value="{{editPlantAlias}}" bindinput="onEditAliasInput"/>
          </view>
          <view class="form-item">
            <text class="form-label">摆放位置</text>
            <input class="form-input" placeholder="例如：客厅、卧室、阳台等" value="{{editPlantLocation}}" bindinput="onEditLocationInput"/>
          </view>
          <view class="form-item">
            <text class="form-label">备注说明</text>
            <textarea class="form-textarea" placeholder="记录养护要点、注意事项等" value="{{editPlantNotes}}" bindinput="onEditNotesInput" maxlength="500"/>
          </view>
        </view>
      </scroll-view>
      <view class="edit-modal-actions">
        <view class="edit-modal-btn edit-modal-btn-cancel" bindtap="closeEditModal">取消</view>
        <view class="edit-modal-btn edit-modal-btn-confirm" bindtap="confirmEdit">保存</view>
      </view>
    </view>
  </view>

  <!-- 删除确认弹窗 -->
  <view wx:if="{{showDeleteModal}}" class="delete-modal-overlay" bindtap="closeDeleteModal">
    <view class="delete-modal-content" catchtap="preventBubble">
      <text class="delete-modal-title">删除植物</text>
      <text class="delete-modal-desc">确定要删除"{{deletePlantName}}"吗？删除后无法恢复。</text>
      <view class="delete-modal-actions">
        <view class="delete-modal-btn delete-modal-btn-cancel" bindtap="closeDeleteModal">取消</view>
        <view class="delete-modal-btn delete-modal-btn-confirm" bindtap="confirmDelete">删除</view>
      </view>
    </view>
  </view>
</view>
