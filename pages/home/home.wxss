/* 养花助手 - 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #F1F8E9 0%, #DCEDC8 50%, #C5E1A5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  position: relative;
  overflow: hidden;
}

/* 大片绿叶浮雕背景 */
.leaf-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.leaf {
  position: absolute;
  opacity: 0.15;
  filter: drop-shadow(0 0 20rpx rgba(76, 175, 80, 0.3));
}

.leaf-1 {
  font-size: 500rpx;
  top: -150rpx;
  left: -120rpx;
  transform: rotate(-25deg);
}

.leaf-2 {
  font-size: 450rpx;
  top: 100rpx;
  right: -150rpx;
  transform: rotate(35deg);
}

.leaf-3 {
  font-size: 400rpx;
  bottom: 50rpx;
  left: -100rpx;
  transform: rotate(-40deg);
}

.leaf-4 {
  font-size: 480rpx;
  bottom: -180rpx;
  right: -80rpx;
  transform: rotate(20deg);
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
  z-index: 1;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 12rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.slogan {
  font-size: 26rpx;
  color: #66BB6A;
}

/* 主功能区 */
.func-section {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  z-index: 1;
}

/* 大按钮 - 拍照识别 */
.main-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 
    0 8rpx 24rpx rgba(76, 175, 80, 0.3),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2);
}

.main-icon {
  font-size: 72rpx;
  margin-right: 28rpx;
}

.main-text {
  display: flex;
  flex-direction: column;
}

.main-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 6rpx;
}

.main-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 并列按钮 */
.sub-btns {
  display: flex;
  gap: 24rpx;
  flex: 1;
}

.sub-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  padding: 36rpx 20rpx;
}

.album-btn {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFE082 100%);
  box-shadow: 
    0 6rpx 20rpx rgba(255, 193, 7, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5);
}

.search-btn {
  background: linear-gradient(135deg, #E0F7FA 0%, #80DEEA 100%);
  box-shadow: 
    0 6rpx 20rpx rgba(0, 188, 212, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5);
}

.sub-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.sub-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.sub-desc {
  font-size: 22rpx;
  color: #888;
}