/* 植物百科大全 - 搜索结果页面样式 */

.container {
  min-height: 100vh;
  background: #E8F5E9;
  padding-bottom: 140rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80vh;
}

.loading-text {
  font-size: 32rpx;
  color: #4CAF50;
}

/* 结果展示 */
.result-container {
  padding: 30rpx;
}

/* 图片区域 */
.image-section {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.plant-image {
  width: 100%;
  height: 100%;
}

/* 信息区域 */
.info-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
}

.name-box {
  text-align: center;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #E8F5E9;
  margin-bottom: 20rpx;
}

.plant-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.plant-scientific {
  display: block;
  font-size: 28rpx;
  color: #999;
  font-style: italic;
  margin-top: 10rpx;
}

.info-box, .care-box {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.info-item {
  margin-bottom: 10rpx;
}

.info-item .label {
  color: #666;
  font-size: 28rpx;
}

.info-item .value {
  color: #333;
  font-size: 28rpx;
}

/* 养殖指南 */
.care-item {
  display: flex;
  align-items: flex-start;
  padding: 15rpx 0;
  border-bottom: 2rpx solid #E0E0E0;
}

.care-item:last-child {
  border-bottom: none;
}

.care-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.care-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 标签 */
.tags-box {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #E8F5E9;
}

.tag {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tag.difficulty {
  background: #E8F5E9;
  color: #4CAF50;
}

.tag.toxicity {
  background: #FFEBEE;
  color: #f44336;
}

.tag.safe {
  background: #E8F5E9;
  color: #4CAF50;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
  text-align: center;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.retry-btn {
  background: #4CAF50;
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.action-btn {
  width: 100%;
  height: 90rpx;
  background: #4CAF50;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
}