<!-- 养花助手 - 首页 -->
<view class="container">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="logo-area">
      <image class="logo-image" src="/image/icons/logo-tree.png" mode="aspectFit"></image>
      <text class="app-name">养花助手</text>
    </view>
    <text class="slogan">拍照识别植物，一键获取养护指南</text>
  </view>

  <!-- 主要操作区 -->
  <view class="main-actions">
    <view class="action-card camera-card" bindtap="takePhoto">
      <image class="action-icon" src="/image/icons/camera-cute.png" mode="aspectFit"></image>
      <text class="action-title">拍照识别</text>
      <text class="action-desc">打开相机拍摄植物</text>
    </view>

    <view class="action-card album-card" bindtap="chooseFromAlbum">
      <image class="action-icon" src="/image/icons/album-cute.png" mode="aspectFit"></image>
      <text class="action-title">相册上传</text>
      <text class="action-desc">从相册选择植物图片</text>
    </view>
  </view>

  <!-- 测试按钮 -->
  <view class="test-section">
    <button class="test-btn" bindtap="testAPI">🔧 测试API连接</button>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goToSearch">
      <image class="entry-icon" src="/image/tab/search-active.png"></image>
      <text class="entry-text">搜索植物</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>🌸 让每个人都能养好花</text>
  </view>
</view>