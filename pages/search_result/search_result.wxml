<!-- 养花助手 - 搜索结果页面 -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">🔍 正在查询...</text>
  </view>

  <!-- 查询结果 -->
  <view class="result-container" wx:if="{{!loading && !error && plant}}">
    <!-- 植物图片 -->
    <view class="plant-image-section" wx:if="{{plant.imageUrl}}">
      <image class="plant-image" src="{{plant.imageUrl}}" mode="aspectFill" binderror="onImageError"></image>
    </view>

    <!-- 植物信息 -->
    <view class="info-section">
      <!-- 名称 -->
      <view class="name-box">
        <text class="plant-name">{{plant.name}}</text>
        <text class="plant-common-names" wx:if="{{plant.commonNames}}">{{plant.commonNames}}</text>
        <text class="plant-scientific" wx:if="{{plant.scientificName}}">学名：{{plant.scientificName}}</text>
        <text class="plant-family" wx:if="{{plant.family}}">科属：{{plant.family}}</text>
        <text class="plant-origin" wx:if="{{plant.origin}}">原产地：{{plant.origin}}</text>
      </view>

      <!-- 详细介绍 -->
      <view class="section-card" wx:if="{{plant.description}}">
        <text class="section-title">📖 详细介绍</text>
        <text class="section-content">{{plant.description}}</text>
      </view>

      <!-- 外观特征 -->
      <view class="info-card" wx:if="{{plant.appearance}}">
        <view class="info-card-header">
          <text class="info-card-icon">🌿</text>
          <text class="info-card-title">外观特征</text>
        </view>
        <text class="info-card-content">{{plant.appearance}}</text>
      </view>

      <!-- 生长习性 -->
      <view class="info-card" wx:if="{{plant.growthHabit}}">
        <view class="info-card-header">
          <text class="info-card-icon">🌱</text>
          <text class="info-card-title">生长习性</text>
        </view>
        <text class="info-card-content">{{plant.growthHabit}}</text>
      </view>

      <!-- 主要价值 -->
      <view class="info-card highlight" wx:if="{{plant.mainValue}}">
        <view class="info-card-header">
          <text class="info-card-icon">💎</text>
          <text class="info-card-title">主要价值</text>
        </view>
        <text class="info-card-content">{{plant.mainValue}}</text>
      </view>

      <!-- 养护难度 -->
      <view class="difficulty-section">
        <view class="section-header">
          <text class="section-title">📊 党护难度</text>
          <view class="difficulty-stars">
            <text wx:for="{{[1,2,3,4,5]}}" wx:key="index" class="star {{item <= plant.difficultyLevel ? 'active' : ''}}">★</text>
          </view>
        </view>
        <text class="difficulty-text">{{plant.difficultyText}}</text>
      </view>

      <!-- 养护指南 -->
      <view class="care-section" wx:if="{{plant.careGuide}}">
        <text class="care-section-title">🌿 党护指南</text>
        
        <view class="care-card" wx:if="{{plant.careGuide.light}}">
          <view class="care-card-header">
            <text class="care-card-icon">☀️</text>
            <text class="care-card-title">光照</text>
          </view>
          <text class="care-card-content">{{plant.careGuide.light}}</text>
        </view>
        
        <view class="care-card" wx:if="{{plant.careGuide.water}}">
          <view class="care-card-header">
            <text class="care-card-icon">💧</text>
            <text class="care-card-title">浇水</text>
          </view>
          <text class="care-card-content">{{plant.careGuide.water}}</text>
        </view>
        
        <view class="care-card" wx:if="{{plant.careGuide.temperature}}">
          <view class="care-card-header">
            <text class="care-card-icon">🌡️</text>
            <text class="care-card-title">温度</text>
          </view>
          <text class="care-card-content">{{plant.careGuide.temperature}}</text>
        </view>

        <view class="care-card" wx:if="{{plant.careGuide.humidity}}">
          <view class="care-card-header">
            <text class="care-card-icon">💦</text>
            <text class="care-card-title">湿度</text>
          </view>
          <text class="care-card-content">{{plant.careGuide.humidity}}</text>
        </view>

        <view class="care-card" wx:if="{{plant.careGuide.fertilizer}}">
          <view class="care-card-header">
            <text class="care-card-icon">🌱</text>
            <text class="care-card-title">施肥</text>
          </view>
          <text class="care-card-content">{{plant.careGuide.fertilizer}}</text>
        </view>
      </view>

      <!-- 快速要点 -->
      <view class="quick-tips" wx:if="{{plant.quickTips && plant.quickTips.length > 0}}">
        <text class="tips-title">⚡ 快速要点</text>
        <view class="tips-list">
          <view class="tip-item" wx:for="{{plant.quickTips}}" wx:key="index">
            <text class="tip-dot">•</text>
            <text class="tip-text">{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 养护禁忌 -->
      <view class="taboos-section" wx:if="{{plant.taboos}}">
        <text class="taboos-title">⚠️ 养护禁忌</text>
        <text class="taboos-content">{{plant.taboos}}</text>
      </view>
    </view>
  </view>

  <!-- 查询失败 -->
  <view class="error-container" wx:if="{{!loading && error}}">
    <text class="error-icon">🔍</text>
    <text class="error-title">未找到 "{{searchText}}" 相关植物</text>
    <text class="error-desc">换个关键词试试？</text>
    <button class="retry-btn" bindtap="goBack">返回搜索</button>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions" wx:if="{{!loading && !error && plant}}">
    <button class="action-btn" bindtap="goBack">继续搜索</button>
  </view>
</view>