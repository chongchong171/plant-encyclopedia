<!-- 花草百科全书 - 拍照页面 -->
<view class="container">
  <!-- 背景装饰 -->
  <view class="leaf-bg">
    <text class="leaf leaf-1">🍃</text>
    <text class="leaf leaf-2">🌿</text>
    <text class="leaf leaf-3">🍃</text>
    <text class="leaf leaf-4">🌿</text>
  </view>

  <!-- 拍摄指导提示 -->
  <view class="card" wx:if="{{showTips}}">
    <view class="card-header">
      <text class="card-icon">{{currentTip.icon}}</text>
      <text class="card-title">{{currentTip.title}}</text>
    </view>
    <view class="card-content">
      <text class="card-text">{{currentTip.desc}}</text>
    </view>
    <view class="tip-dots">
      <text class="dot {{currentIndex === 0 ? 'active' : ''}}">●</text>
      <text class="dot {{currentIndex === 1 ? 'active' : ''}}">●</text>
      <text class="dot {{currentIndex === 2 ? 'active' : ''}}">●</text>
    </view>
    <view class="tip-close" bindtap="hideTips">✕</view>
  </view>

  <!-- 操作按钮区 -->
  <view class="action-section">
    <!-- 拍照按钮 -->
    <button class="btn-primary" open-type="chooseMedia" bindchoosemedia="onTakePhoto">
      📷 拍照识别
    </button>
    
    <!-- 相册按钮 -->
    <button class="btn-secondary" open-type="chooseMedia" bindchoosemedia="onChooseFromAlbum">
      🖼️ 相册上传
    </button>
  </view>

  <!-- 返回按钮 -->
  <button class="btn-text back-btn" bindtap="goBack">← 返回</button>
</view>