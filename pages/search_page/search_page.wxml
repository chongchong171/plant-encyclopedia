<!-- 养花助手 - 搜索页面 -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-box" bindtap="goToSearchDetail">
      <text class="search-placeholder">🔍 搜索植物名称...</text>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="hot-section">
    <text class="section-title">🔥 热门植物</text>
    <view class="hot-tags">
      <view 
        class="hot-tag" 
        wx:for="{{hotPlants}}" 
        wx:key="index"
        data-text="{{item}}"
        bindtap="searchPlant"
      >{{item}}</view>
    </view>
  </view>

  <!-- 植物分类 -->
  <view class="category-section">
    <text class="section-title">🌿 植物分类</text>
    <view class="category-list">
      <view 
        class="category-item" 
        wx:for="{{categories}}" 
        wx:key="id"
        data-category="{{item.name}}"
        bindtap="searchPlant"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>
</view>