/* 花草百科全书 - 拍照页面 */

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  background: #E8F5E9;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  position: relative;
}

/* ========== 背景装饰 ========== */
.leaf-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.leaf {
  position: absolute;
  font-size: 80rpx;
  opacity: 0.1;
  animation: float 6s ease-in-out infinite;
}

.leaf-1 { top: 10%; left: 10%; animation-delay: 0s; }
.leaf-2 { top: 30%; right: 15%; animation-delay: 1.5s; }
.leaf-3 { bottom: 30%; left: 20%; animation-delay: 3s; }
.leaf-4 { bottom: 10%; right: 10%; animation-delay: 4.5s; }

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-30rpx) rotate(10deg); }
}

/* ========== 卡片组件（标准） ========== */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  margin-top: 80rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  position: relative;
  width: 100%;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

.card-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.card-text {
  color: #555;
}

/* ========== 提示点 ========== */
.tip-dots {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.dot {
  font-size: 20rpx;
  color: #E0E0E0;
  margin: 0 8rpx;
  transition: color 0.3s;
}

.dot.active {
  color: #4CAF50;
}

.tip-close {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 56rpx;
  height: 56rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* ========== 操作按钮区 ========== */
.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-top: 40rpx;
}

/* ========== 主要按钮（标准） ========== */
.btn-primary {
  width: 100%;
  height: 90rpx;
  background: #4CAF50;
  color: white;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.28);
}

.btn-primary::after {
  border: none;
}

/* ========== 次要按钮（标准） ========== */
.btn-secondary {
  width: 100%;
  height: 90rpx;
  background: white;
  color: #4CAF50;
  border: 4rpx solid #4CAF50;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary::after {
  border: none;
}

/* ========== 文字按钮（标准） ========== */
.btn-text {
  background: transparent;
  color: #4CAF50;
  font-size: 28rpx;
}

.btn-text::after {
  border: none;
}

/* ========== 返回按钮 ========== */
.back-btn {
  position: fixed;
  top: 40rpx;
  left: 40rpx;
  background: rgba(255, 255, 255, 0.9);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}