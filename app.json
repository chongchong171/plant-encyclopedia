{
  "pages": [
    "pages/home/home",
    "pages/my-plants/my-plants",
    "pages/discover/discover",
    "pages/profile/profile"
  ],
  "subpackages": [
    {
      "root": "package-camera",
      "pages": [
        "pages/camera/camera",
        "pages/result_swiper/result_swiper"
      ]
    },
    {
      "root": "package-plant",
      "pages": [
        "pages/plant-detail/plant-detail",
        "pages/search_result/search_result",
        "pages/search_page/search_page",
        "pages/category_list/category_list"
      ]
    },
    {
      "root": "package-user",
      "pages": [
        "pages/favorites/favorites",
        "pages/history/history",
        "pages/diagnosis/diagnosis",
        "pages/community-garden/community-garden",
        "pages/shop/shop"
      ]
    },
    {
      "root": "package-admin",
      "pages": [
        "pages/admin/admin",
        "pages/admin/dashboard"
      ]
    }
  ],
  "preloadRule": {
    "pages/home/home": {
      "network": "all",
      "packages": ["package-camera"]
    },
    "pages/discover/discover": {
      "network": "all",
      "packages": ["package-plant"]
    }
  },
  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "花草百科",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f8f9fa"
  },
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "selectedColor": "#4CAF50",
    "backgroundColor": "#1a3a2f",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "首页",
        "iconPath": "/image/tab/home-white.png",
        "selectedIconPath": "/image/tab/home-active.png"
      },
      {
        "pagePath": "pages/my-plants/my-plants",
        "text": "花园",
        "iconPath": "/image/tab/garden-white.png",
        "selectedIconPath": "/image/tab/garden-active.png"
      },
      {
        "pagePath": "pages/discover/discover",
        "text": "发现",
        "iconPath": "/image/tab/discover-white.png",
        "selectedIconPath": "/image/tab/discover-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "/image/tab/user-white.png",
        "selectedIconPath": "/image/tab/user-active.png"
      }
    ]
  },
  "cloud": true,
  "style": "v2",
  "lazyCodeLoading": "requiredComponents",
  "sitemapLocation": "sitemap.json"
}