<!-- 收藏页面 -->
<view class="container">
  <!-- 调试信息 -->
  <view style="padding: 20rpx; background: #f0f0f0; margin-bottom: 20rpx;">
    <text style="font-size: 24rpx; color: #999;">调试: 收藏数量 = {{favorites.length}}</text>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{favorites.length === 0}}">
    <text class="empty-icon">❤️</text>
    <text class="empty-title">暂无收藏</text>
    <text class="empty-desc">识别植物后可以收藏喜欢的植物</text>
    <button class="go-btn" bindtap="goToHome">去识别</button>
  </view>

  <!-- 收藏列表 -->
  <view class="favorites-list" wx:else>
    <view class="list-header">
      <text class="list-title">我的收藏</text>
      <text class="list-count">{{favorites.length}} 种植物</text>
    </view>

    <view 
      class="favorite-item" 
      wx:for="{{favorites}}" 
      wx:key="id"
      data-plant="{{item}}"
      bindtap="goToDetail"
    >
      <image class="plant-image" src="{{item.imageUrl || item.image}}" mode="aspectFill"></image>
      <view class="plant-info">
        <text class="plant-name">{{item.name}}</text>
        <text class="plant-family">{{item.family || '未知科属'}}</text>
        <text class="add-time">{{item.addTimeStr}}</text>
      </view>
      <view class="remove-btn" catchtap="removeFavorite" data-id="{{item.id}}">
        <text class="remove-icon">🗑️</text>
      </view>
    </view>
  </view>
</view>