/* diagnosis.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* ========== 步骤区域 ========== */
.step-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 紧凑版本 */
.step-section--compact {
  padding: 16rpx 24rpx;
}

.step-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.step-number {
  width: 36rpx;
  height: 36rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.step-required {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-left: 8rpx;
}

/* ========== 植物选择器（紧凑版） ========== */
.plant-selector {
  min-height: 60rpx;
}

.no-plant-selected {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.no-plant-icon {
  font-size: 32rpx;
}

.no-plant-text {
  font-size: 26rpx;
  color: #666;
}

.selected-plant {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.selected-plant-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.selected-plant-image {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
}

.selected-plant-name {
  font-size: 28rpx;
  color: #333;
}

.change-btn {
  font-size: 24rpx;
  color: #1890ff;
  padding: 8rpx 16rpx;
  background: #e6f7ff;
  border-radius: 20rpx;
}

/* ========== 图片上传（紧凑版） ========== */
.image-uploader {
  min-height: 60rpx;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 80rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx dashed #ddd;
}

.upload-icon {
  font-size: 32rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #666;
}

.uploaded-image {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.uploaded-image image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.delete-image {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* ========== 诊断按钮 ========== */
.diagnosis-btn-wrapper {
  padding: 30rpx 0;
}

.diagnosis-btn {
  width: 100%;
  height: 90rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 500;
}

.diagnosis-btn--disabled {
  background: #ccc;
}

/* ========== 结果区域 ========== */
.result-section {
  margin-top: 40rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #f6ffed;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.result-icon {
  font-size: 36rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #52c41a;
}

.result-time {
  font-size: 24rpx;
  color: #666;
  margin-left: auto;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.result-card--causes {
  border-left: 8rpx solid #1890ff;
}

.result-card--solutions {
  border-left: 8rpx solid #52c41a;
}

.result-card--products {
  border-left: 8rpx solid #faad14;
}

.result-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.result-card-icon {
  font-size: 32rpx;
}

.result-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.result-item-index {
  width: 32rpx;
  height: 32rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
}

.result-item-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.result-empty {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
  font-style: italic;
}

/* ========== 推荐商品 ========== */
.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.product-item:hover {
  background: #f0f0f0;
  transform: translateY(-2rpx);
}

.product-info {
  flex: 1;
  margin-right: 16rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.product-description {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

.product-price {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 500;
  white-space: nowrap;
}

/* ========== 保存按钮 ========== */
.save-btn {
  width: 100%;
  height: 80rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin-top: 30rpx;
}

/* ========== 植物选择弹窗 ========== */
.picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 36rpx;
  color: #666;
}

.picker-list {
  padding: 16rpx;
}

.picker-empty {
  text-align: center;
  padding: 40rpx;
  color: #666;
}

.picker-item {
  margin-bottom: 12rpx;
}

/* AI 生成标识 - 低调合规 */
.ai-generate-tag {
  text-align: center;
  padding: 12rpx 0;
  margin-top: 16rpx;
  border-top: 1rpx solid #E8E8E8;
}

.ai-tag-text {
  font-size: 22rpx;
  color: #999;
  letter-spacing: 0.5rpx;
}