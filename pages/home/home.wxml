<!-- 养花助手 - 首页 -->
<view class="container">
  <!-- Logo -->
  <view class="logo-section">
    <text class="logo-icon">🌳</text>
    <text class="app-name">养花助手</text>
    <text class="slogan">拍照识别，一键养护</text>
  </view>

  <!-- 主要功能 -->
  <view class="main-section">
    <!-- 拍照按钮 -->
    <view class="primary-btn" bindtap="takePhoto">
      <text class="btn-icon">📷</text>
      <view class="btn-content">
        <text class="btn-title">拍照识别</text>
        <text class="btn-desc">拍摄植物，获取养护指南</text>
      </view>
    </view>

    <!-- 相册按钮 -->
    <view class="secondary-btn" bindtap="chooseFromAlbum">
      <text class="btn-icon">🖼️</text>
      <text class="btn-title">相册上传</text>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-section">
    <view class="quick-item" bindtap="goToSearch">
      <text class="quick-icon">🔍</text>
      <text class="quick-text">搜索植物</text>
    </view>
  </view>
</view>