/* 养花助手 - 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #E8F5E9 0%, #C8E6C9 50%, #A5D6A7 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 36rpx;
  position: relative;
  overflow: hidden;
}

/* 大片绿叶浮雕背景 */
.leaf-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.leaf-shape {
  position: absolute;
  border-radius: 50% 0 50% 50%;
  background: linear-gradient(135deg, #81C784 0%, #66BB6A 100%);
  opacity: 0.25;
}

.leaf-1 {
  width: 300rpx;
  height: 400rpx;
  top: -100rpx;
  left: -80rpx;
  transform: rotate(-20deg);
}

.leaf-2 {
  width: 350rpx;
  height: 450rpx;
  top: 50rpx;
  right: -120rpx;
  transform: rotate(30deg);
  opacity: 0.2;
}

.leaf-3 {
  width: 280rpx;
  height: 380rpx;
  top: 350rpx;
  left: -100rpx;
  transform: rotate(-35deg);
  opacity: 0.18;
}

.leaf-4 {
  width: 320rpx;
  height: 420rpx;
  bottom: 150rpx;
  right: -80rpx;
  transform: rotate(25deg);
  opacity: 0.22;
}

.leaf-5 {
  width: 400rpx;
  height: 500rpx;
  bottom: -150rpx;
  left: 50rpx;
  transform: rotate(-15deg);
  opacity: 0.15;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  z-index: 1;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.slogan {
  font-size: 26rpx;
  color: #4CAF50;
}

/* 主功能区 */
.func-section {
  width: 100%;
  z-index: 1;
}

/* 大按钮 - 拍照识别 */
.main-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(76, 175, 80, 0.15);
}

.btn-left {
  display: flex;
  align-items: center;
}

.btn-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.btn-text {
  display: flex;
  flex-direction: column;
}

.btn-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.btn-desc {
  font-size: 24rpx;
  color: #888;
}

.btn-arrow {
  font-size: 40rpx;
  color: #A5D6A7;
}

/* 并列按钮 */
.sub-btns {
  display: flex;
  gap: 20rpx;
}

.sub-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.album-btn {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.search-btn {
  background: linear-gradient(135deg, #E0F2F1 0%, #B2DFDB 100%);
}

.sub-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 底部 */
.footer {
  margin-top: auto;
  padding-top: 40rpx;
  z-index: 1;
}

.footer text {
  font-size: 24rpx;
  color: #81C784;
}