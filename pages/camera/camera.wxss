/* 养花助手 - 拍照页面样式 */

.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  background: #000;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 授权提示 */
.auth-tip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #1B5E20 0%, #2E7D32 50%, #4CAF50 100%);
}

.auth-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 40rpx;
}

.auth-btn {
  background: white;
  color: #4CAF50;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 拍摄指导提示 */
.photo-tips {
  position: absolute;
  top: 80rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  align-items: flex-start;
}

.tip-card {
  flex: 1;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 16rpx;
  padding: 24rpx;
  backdrop-filter: blur(10px);
}

.tip-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.tip-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

.tip-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}

.tip-dots {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.dot {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
}

.dot.active {
  color: #4CAF50;
}

.tip-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  margin-left: 16rpx;
}

/* 控制栏 */
.controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 60rpx;
}

.btn-back {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid white;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
}

.btn-capture {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 8rpx solid white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.capture-inner {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: white;
}

.btn-album {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}