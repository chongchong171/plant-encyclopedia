<!-- 植物百科大全 - 首页 -->
<view class="container">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="logo-area">
      <text class="logo-emoji">🌱</text>
      <text class="app-name">植物百科大全</text>
    </view>
    <text class="slogan">拍照识别植物，一键获取养殖指南</text>
  </view>

  <!-- 主要操作区 -->
  <view class="main-actions">
    <view class="action-card camera-card" bindtap="takePhoto">
      <image class="action-icon" src="/image/tab/scan-active.png"></image>
      <text class="action-title">拍照识别</text>
      <text class="action-desc">打开相机拍摄植物</text>
    </view>

    <view class="action-card album-card" bindtap="chooseFromAlbum">
      <text class="action-emoji">🖼️</text>
      <text class="action-title">相册上传</text>
      <text class="action-desc">从相册选择植物图片</text>
    </view>
  </view>

  <!-- 识别次数提示 -->
  <view class="count-tip" wx:if="{{!vipUser}}">
    <text>今日剩余识别次数：{{identifyLimit - identifyCount}} 次</text>
    <text class="vip-link" bindtap="showVipInfo">开通VIP无限识别</text>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goToSearch">
      <image class="entry-icon" src="/image/tab/search-active.png"></image>
      <text class="entry-text">搜索植物</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>🌱 让每个人都能养好花</text>
  </view>
</view>