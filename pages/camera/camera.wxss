/* 植物百科大全 - 拍照页面样式 */

.container {
  width: 100vw;
  height: 100vh;
  position: relative;
}

.camera {
  width: 100%;
  height: 100%;
}

.controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 60rpx;
}

.btn-back {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid white;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
}

.btn-capture {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 8rpx solid white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.capture-inner {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: white;
}

.btn-album {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}