/* 养花助手 - 分类列表页面样式 */

.container {
  min-height: 100vh;
  background: #E8F5E9;
  padding: 30rpx;
}

/* 加载中 */
.loading-section {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 分类头部 */
.category-header {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.category-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.category-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 植物列表 */
.plant-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.plant-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.plant-item:last-child {
  border-bottom: none;
}

.plant-info {
  flex: 1;
}

.plant-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.plant-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.plant-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}