<!-- 养花助手 - 首页 -->
<view class="container">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="logo-area">
      <view class="logo-icon">🌳</view>
      <text class="app-name">养花助手</text>
    </view>
    <text class="slogan">拍照识别植物，一键获取养护指南</text>
  </view>

  <!-- 主要操作区 -->
  <view class="main-actions">
    <view class="action-card camera-card" bindtap="takePhoto">
      <view class="action-emoji">📷</view>
      <text class="action-title">拍照识别</text>
      <text class="action-desc">打开相机拍摄植物</text>
    </view>

    <view class="action-card album-card" bindtap="chooseFromAlbum">
      <view class="action-emoji">🖼️</view>
      <text class="action-title">相册上传</text>
      <text class="action-desc">从相册选择植物图片</text>
    </view>
  </view>

  <!-- 搜索植物入口 -->
  <view class="search-section">
    <view class="search-card" bindtap="goToSearch">
      <view class="search-left">
        <text class="search-emoji">🔍</text>
        <view class="search-info">
          <text class="search-title">搜索植物</text>
          <text class="search-desc">查找植物百科和养护知识</text>
        </view>
      </view>
      <text class="search-arrow">›</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>🌸 让每个人都能养好花</text>
  </view>
</view>