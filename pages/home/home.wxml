<!-- 花草百科全书 - 首页 -->
<view class="container">
  <!-- 大片绿叶浮雕背景 -->
  <view class="leaf-bg">
    <text class="leaf leaf-1">🍃</text>
    <text class="leaf leaf-2">🌿</text>
    <text class="leaf leaf-3">🍃</text>
    <text class="leaf leaf-4">🌿</text>
  </view>

  <!-- Logo -->
  <view class="logo-section">
    <text class="logo-icon">🌳</text>
    <text class="app-name">花草百科全书</text>
    <text class="slogan">遇见植物的美好</text>
  </view>

  <!-- 主功能区 -->
  <view class="func-section">
    <!-- 拍照识别 - 大按钮 -->
    <view class="main-btn" bindtap="takePhoto">
      <text class="main-icon">📷</text>
      <view class="main-text">
        <text class="main-title">拍照识别</text>
        <text class="main-desc">拍一拍，认识你的植物</text>
      </view>
    </view>

    <!-- 相册和搜索 - 并列 -->
    <view class="sub-btns">
      <view class="sub-btn album-btn" bindtap="chooseFromAlbum">
        <text class="sub-icon">🖼️</text>
        <text class="sub-title">相册上传</text>
      </view>
      <view class="sub-btn search-btn" bindtap="goToSearch">
        <text class="sub-icon">🔍</text>
        <text class="sub-title">搜索植物</text>
      </view>
    </view>

    <!-- 底部 Slogan -->
    <view class="footer-slogan">
      <text>🌱 每一片叶子，都有它的故事</text>
    </view>
  </view>
</view>