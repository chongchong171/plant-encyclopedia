/* 植物百科大全 - 识别结果页样式 */

.container {
  min-height: 100vh;
  background: #E8F5E9;
}

/* 加载中 */
.loading-container {
  position: relative;
  width: 100%;
  height: 100vh;
}

.loading-image {
  width: 100%;
  height: 100%;
  filter: blur(10rpx);
}

.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  background: white;
  padding: 40rpx 80rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  color: #4CAF50;
}

/* 识别失败 */
.error-container {
  padding: 40rpx;
  text-align: center;
}

.error-image {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
}

.error-content {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
}

.error-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #f44336;
  margin-bottom: 20rpx;
}

.error-message {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.retry-btn {
  background: #4CAF50;
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
}

/* 结果展示 */
.result-container {
  padding-bottom: 140rpx;
}

/* 植物图片 */
.plant-image-container {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.plant-image {
  width: 100%;
  height: 100%;
}

.favorite-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-icon {
  font-size: 40rpx;
}

/* 植物信息 */
.plant-info {
  padding: 30rpx;
  margin-top: -40rpx;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  position: relative;
}

.name-section {
  text-align: center;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #E8F5E9;
  margin-bottom: 30rpx;
}

.plant-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.plant-scientific {
  display: block;
  font-size: 28rpx;
  color: #999;
  font-style: italic;
  margin-bottom: 20rpx;
}

.tags {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tag-difficulty {
  background: #E8F5E9;
  color: #4CAF50;
}

.tag-toxicity {
  background: #FFEBEE;
  color: #f44336;
}

.tag-safe {
  background: #E8F5E9;
  color: #4CAF50;
}

/* 信息区块 */
.info-section,
.care-section,
.features-section {
  background: #F5F5F5;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.info-item {
  margin-bottom: 15rpx;
}

.info-label {
  color: #666;
  font-size: 28rpx;
}

.info-value {
  color: #333;
  font-size: 28rpx;
}

/* 养殖指南 */
.care-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #E0E0E0;
}

.care-item:last-child {
  border-bottom: none;
}

.care-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 50rpx;
}

.care-content {
  flex: 1;
}

.care-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.care-value {
  display: block;
  font-size: 28rpx;
  color: #333;
}

/* 特点 */
.features-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feature-tag {
  background: white;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  gap: 30rpx;
}

.action-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: #4CAF50;
  color: white;
}

.action-btn.secondary {
  background: white;
  color: #4CAF50;
  border: 4rpx solid #4CAF50;
}