/* plant-card.wxss */
/* 植物卡片组件 - 现代简约风格 */

/* ========== 卡片容器 ========== */
.plant-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  position: relative;
  transition: all 0.2s ease;
}

.plant-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

/* ========== 图片区域 ========== */
.plant-card__image-wrapper {
  width: 120rpx;
  height: 120rpx;
  position: relative;
  flex-shrink: 0;
}

.plant-card__image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  object-fit: cover;
}

/* ========== 浇水角标 ========== */
.water-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.water-badge--urgent {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  animation: pulse 1.5s ease-in-out infinite;
}

.water-badge--soon {
  background: linear-gradient(135deg, #ffc107 0%, #ffb300 100%);
  color: #fff;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* ========== 信息区域 ========== */
.plant-card__info {
  flex: 1;
  padding: 0 20rpx;
  min-width: 0;
}

.plant-card__name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plant-card__scientific {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
  font-style: italic;
}

.plant-card__water-status {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

.plant-card__water-status--urgent {
  color: #ff4d4f;
}

.plant-card__light {
  font-size: 24rpx;
  color: #faad14;
  margin-top: 6rpx;
}

/* ========== 操作按钮 ========== */
.plant-card__actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.action-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.action-btn__icon {
  font-size: 28rpx;
}

.action-btn__text {
  font-size: 18rpx;
  margin-top: 2rpx;
  color: #666;
}

/* 浇水按钮 */
.action-btn--water {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

/* 施肥按钮 */
.action-btn--fertilize {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

/* 删除按钮 */
.action-btn--delete {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
  position: relative;
  z-index: 10;
}

.action-btn--delete .action-btn__text {
  color: #d32f2f;
  font-weight: 500;
}

/* ========== 模式变体 ========== */

/* 网格模式 */
.plant-card--grid {
  flex-direction: column;
  width: 50%;
  padding: 16rpx;
}

.plant-card--grid .plant-card__image-wrapper {
  width: 100%;
  height: 180rpx;
  margin-bottom: 16rpx;
}

.plant-card--grid .plant-card__image {
  width: 100%;
  height: 180rpx;
}

.plant-card--grid .plant-card__info {
  padding: 0;
  text-align: center;
  width: 100%;
}

.plant-card--grid .plant-card__actions {
  display: none;
}

/* 紧凑模式 */
.plant-card--compact {
  padding: 16rpx;
}

.plant-card--compact .plant-card__image-wrapper {
  width: 88rpx;
  height: 88rpx;
}

.plant-card--compact .plant-card__image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 14rpx;
}

.plant-card--compact .plant-card__name {
  font-size: 30rpx;
}

.plant-card--compact .plant-card__actions {
  display: none;
}