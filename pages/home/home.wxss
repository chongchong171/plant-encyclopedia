/* 养花助手 - 首页样式 */

.container {
  min-height: 100vh;
  background: #4CAF50;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 36rpx;
  position: relative;
  overflow: hidden;
}

/* 大片绿叶浮雕背景 */
.leaf-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.leaf {
  position: absolute;
  font-size: 280rpx;
  opacity: 0.12;
  color: #2E7D32;
}

.leaf-1 {
  top: -60rpx;
  left: -80rpx;
  transform: rotate(-30deg);
  font-size: 320rpx;
}

.leaf-2 {
  top: 100rpx;
  right: -100rpx;
  transform: rotate(20deg);
  font-size: 260rpx;
}

.leaf-3 {
  top: 400rpx;
  left: -60rpx;
  transform: rotate(-15deg);
  font-size: 240rpx;
}

.leaf-4 {
  bottom: 200rpx;
  right: -40rpx;
  transform: rotate(35deg);
  font-size: 280rpx;
}

.leaf-5 {
  bottom: -80rpx;
  left: 40rpx;
  transform: rotate(-25deg);
  font-size: 300rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  z-index: 1;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 主功能区 */
.func-section {
  width: 100%;
  z-index: 1;
}

/* 大按钮 - 拍照识别 */
.main-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.main-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.main-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.main-desc {
  font-size: 26rpx;
  color: #888;
}

/* 并列按钮 */
.sub-btns {
  display: flex;
  gap: 20rpx;
}

.sub-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.sub-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 底部 */
.footer {
  margin-top: auto;
  padding-top: 40rpx;
  z-index: 1;
}

.footer text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}