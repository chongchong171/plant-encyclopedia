<!-- 个人中心页面 -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-avatar">
      <text class="avatar-text">🌱</text>
    </view>
    <text class="user-name">植物爱好者</text>
    <view class="vip-badge" wx:if="{{vipUser}}">
      <text>VIP会员</text>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stat-item" bindtap="goToHistory">
      <text class="stat-value">{{totalCount}}</text>
      <text class="stat-label">识别次数</text>
    </view>
    <view class="stat-item" bindtap="goToFavorites">
      <text class="stat-value">{{favoriteCount}}</text>
      <text class="stat-label">收藏植物</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{todayCount}}</text>
      <text class="stat-label">今日识别</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="showVipInfo">
      <text class="menu-icon">👑</text>
      <text class="menu-text">开通VIP</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="showFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">花草百科全书 v1.0.0</text>
    <text class="footer-text">让每个人都能养好花 🌸</text>
  </view>
</view>