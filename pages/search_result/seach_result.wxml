<!-- 养花助手 - 搜索结果页面 -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">🔍 正在查询...</text>
  </view>

  <!-- 查询结果 -->
  <view class="result-container" wx:if="{{!loading && !error}}">
    <!-- 植物图片 -->
    <view class="image-section" wx:if="{{plant.image}}">
      <image class="plant-image" src="{{plant.image}}" mode="aspectFill"></image>
    </view>

    <!-- 植物信息 -->
    <view class="info-section">
      <!-- 名称 -->
      <view class="name-box">
        <text class="plant-name">{{plant.name}}</text>
        <text class="plant-scientific" wx:if="{{plant.scientificName}}">{{plant.scientificName}}</text>
      </view>

      <!-- 基本信息 -->
      <view class="info-box">
        <text class="info-title">📋 基本信息</text>
        <view class="info-item" wx:if="{{plant.family}}">
          <text class="label">科属：</text>
          <text class="value">{{plant.family}}</text>
        </view>
        <view class="info-item" wx:if="{{plant.description}}">
          <text class="label">简介：</text>
          <text class="value">{{plant.description}}</text>
        </view>
      </view>

      <!-- 养殖指南 -->
      <view class="care-box" wx:if="{{plant.careGuide}}">
        <text class="info-title">🌿 养殖指南</text>
        
        <view class="care-item" wx:if="{{plant.careGuide.light}}">
          <text class="care-icon">☀️</text>
          <text class="care-text">{{plant.careGuide.light}}</text>
        </view>
        
        <view class="care-item" wx:if="{{plant.careGuide.water}}">
          <text class="care-icon">💧</text>
          <text class="care-text">{{plant.careGuide.water}}</text>
        </view>
        
        <view class="care-item" wx:if="{{plant.careGuide.temperature}}">
          <text class="care-icon">🌡️</text>
          <text class="care-text">{{plant.careGuide.temperature}}</text>
        </view>
        
        <view class="care-item" wx:if="{{plant.careGuide.humidity}}">
          <text class="care-icon">💦</text>
          <text class="care-text">{{plant.careGuide.humidity}}</text>
        </view>
        
        <view class="care-item" wx:if="{{plant.careGuide.fertilizer}}">
          <text class="care-icon">🌱</text>
          <text class="care-text">{{plant.careGuide.fertilizer}}</text>
        </view>
        
        <view class="care-item" wx:if="{{plant.careGuide.tips}}">
          <text class="care-icon">💡</text>
          <text class="care-text">{{plant.careGuide.tips}}</text>
        </view>
      </view>

      <!-- 标签 -->
      <view class="tags-box">
        <text class="tag difficulty" wx:if="{{plant.difficulty}}">{{plant.difficulty}}</text>
        <text class="tag toxicity" wx:if="{{plant.toxicity}}">⚠️ 有毒</text>
        <text class="tag safe" wx:else>✅ 无毒</text>
      </view>
    </view>
  </view>

  <!-- 查询失败 -->
  <view class="error-container" wx:if="{{!loading && error}}">
    <text class="error-icon">🔍</text>
    <text class="error-title">未找到 "{{searchText}}" 相关植物</text>
    <text class="error-desc">换个关键词试试？</text>
    <button class="retry-btn" bindtap="goBack">返回搜索</button>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions" wx:if="{{!loading && !error}}">
    <button class="action-btn" bindtap="goBack">继续搜索</button>
  </view>
</view>