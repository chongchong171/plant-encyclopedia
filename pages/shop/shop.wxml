<!--植物商城页面-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">🛒 植物商城</text>
    <text class="subtitle">精选好物，为你的植物生活添彩</text>
  </view>

  <!-- 分类标签 -->
  <view class="categories">
    <view 
      class="category-item" 
      wx:for="{{categories}}" 
      wx:key="id"
      bindtap="switchCategory"
      data-id="{{item.id}}"
    >
      <text class="category-icon">{{item.icon}}</text>
      <text class="category-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-title">商城正在筹备中</text>
    <text class="empty-desc">敬请期待精选植物好物</text>
  </view>

  <!-- 商品列表（未来开发） -->
  <view class="product-list" wx:if="{{products.length > 0}}">
    <view 
      class="product-item" 
      wx:for="{{products}}" 
      wx:key="id"
      bindtap="goToProduct"
      data-id="{{item.id}}"
    >
      <image class="product-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>
</view>