/* 养花助手 - 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4CAF50 0%, #81C784 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
}

.slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 主要功能区 */
.main-section {
  width: 100%;
  margin-bottom: 40rpx;
}

/* 主按钮 - 拍照 */
.primary-btn {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.btn-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.btn-content {
  display: flex;
  flex-direction: column;
}

.btn-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.btn-desc {
  font-size: 24rpx;
  color: #888;
}

/* 次按钮 - 相册 */
.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.secondary-btn .btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.secondary-btn .btn-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #4CAF50;
}

/* 快捷功能 */
.quick-section {
  display: flex;
  gap: 24rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 20rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.quick-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.quick-text {
  font-size: 26rpx;
  color: #333;
}