<!-- 花草百科全书 - 拍照页面 -->
<view class="container">
  <!-- 背景装饰 -->
  <view class="leaf-bg">
    <text class="leaf leaf-1">🍃</text>
    <text class="leaf leaf-2">🌿</text>
    <text class="leaf leaf-3">🍃</text>
    <text class="leaf leaf-4">🌿</text>
  </view>

  <!-- 拍摄指导提示 -->
  <view class="photo-tips" wx:if="{{showTips}}">
    <view class="tip-card">
      <view class="tip-header">
        <text class="tip-icon">{{currentTip.icon}}</text>
        <text class="tip-title">{{currentTip.title}}</text>
      </view>
      <text class="tip-desc">{{currentTip.desc}}</text>
      <view class="tip-dots">
        <text class="dot {{currentIndex === 0 ? 'active' : ''}}">●</text>
        <text class="dot {{currentIndex === 1 ? 'active' : ''}}">●</text>
        <text class="dot {{currentIndex === 2 ? 'active' : ''}}">●</text>
      </view>
    </view>
    <view class="tip-close" bindtap="hideTips">✕</view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <view class="action-btn camera-btn" bindtap="takePhoto">
      <text class="action-icon">📷</text>
      <text class="action-title">拍照识别</text>
      <text class="action-desc">拍一张植物照片</text>
    </view>
    
    <view class="action-btn album-btn" bindtap="chooseFromAlbum">
      <text class="action-icon">🖼️</text>
      <text class="action-title">相册上传</text>
      <text class="action-desc">从相册选择图片</text>
    </view>
  </view>

  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text>← 返回</text>
  </view>
</view>